{
  "name": "stealth-trails-bank",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "./scripts/dev.sh",
    "dev:mobile": "node ./scripts/dev-mobile.mjs",
    "dev:preflight": "node ./scripts/preflight-dev.mjs",
    "prepare": "pnpm setup:hooks",
    "build:apps": "turbo build",
    "build": "turbo build",
    "serve:apps": "node ./scripts/serve-built.mjs",
    "build:serve": "pnpm build:apps && pnpm serve:apps",
    "lint": "turbo lint",
    "test": "turbo test",
    "test:push": "node --test ./scripts/push.spec.mjs",
    "test:unit": "pnpm --filter @stealth-trails-bank/api test:unit && pnpm --filter @stealth-trails-bank/worker test && pnpm --filter @stealth-trails-bank/web test && pnpm --filter @stealth-trails-bank/admin test",
    "test:integration": "pnpm --filter @stealth-trails-bank/api test:integration && pnpm --filter @stealth-trails-bank/contracts test",
    "test:e2e": "playwright test",
    "test:coverage": "pnpm --filter @stealth-trails-bank/api test:coverage && pnpm --filter @stealth-trails-bank/worker test:coverage && pnpm --filter @stealth-trails-bank/web test:coverage && pnpm --filter @stealth-trails-bank/admin test:coverage",
    "test:ci": "pnpm test:push && pnpm build && pnpm api:smoke:local && pnpm lint && pnpm test:unit && pnpm test:integration && pnpm test:coverage && pnpm test:e2e && pnpm mobile:verify",
    "compile": "turbo run compile",
    "release:readiness:probe": "pnpm --filter @stealth-trails-bank/api release-readiness:probe",
    "release:readiness:verify": "pnpm --filter @stealth-trails-bank/api release-readiness:verify",
    "release:launch-closure": "pnpm --filter @stealth-trails-bank/api release-launch-closure",
    "mobile:android": "pnpm --filter @stealth-trails-bank/mobile android",
    "mobile:ios": "pnpm --filter @stealth-trails-bank/mobile ios",
    "mobile:typecheck": "pnpm --filter @stealth-trails-bank/mobile exec tsc --noEmit",
    "mobile:test": "pnpm --filter @stealth-trails-bank/mobile test",
    "mobile:export": "EXPO_PUBLIC_API_BASE_URL=http://localhost:3000 pnpm --filter @stealth-trails-bank/mobile exec expo export --platform web",
    "mobile:verify": "pnpm mobile:typecheck && pnpm mobile:test && pnpm mobile:export",
    "db:supabase:check": "node ./scripts/supabase-db-cutover.mjs check-env",
    "db:supabase:migrate": "node ./scripts/supabase-db-cutover.mjs migrate",
    "db:supabase:dump-local": "node ./scripts/supabase-db-cutover.mjs dump-local",
    "db:supabase:import": "node ./scripts/supabase-db-cutover.mjs import-data",
    "db:supabase:compare-counts": "node ./scripts/supabase-db-cutover.mjs compare-counts",
    "hooks:check": "node ./scripts/check-hooks.mjs",
    "api:smoke": "node ./scripts/api-smoke.mjs",
    "api:smoke:local": "node ./scripts/api-smoke.mjs --local",
    "verify:push": "./scripts/verify-push.sh",
    "push": "node ./scripts/push.mjs",
    "safe-push": "./scripts/safe-push.sh",
    "setup:hooks": "node ./scripts/setup-hooks.mjs"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.2",
    "turbo": "^2.4.4"
  }
}
