datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id              Int              @id @default(autoincrement())
  firstName       String
  lastName        String
  email           String           @unique
  supabaseUserId  String
  ethereumAddress String?          @default("")
  createdAt       DateTime         @default(now())
  deposits        PoolDeposit[]
  withdrawals     PoolWithdrawal[]
}

model Customer {
  id             String            @id @default(cuid())
  supabaseUserId String            @unique
  email          String            @unique
  firstName      String?
  lastName       String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  accounts       CustomerAccount[]
}

model CustomerAccount {
  id           String                 @id @default(cuid())
  customerId   String                 @unique
  customer     Customer               @relation(fields: [customerId], references: [id])
  status       AccountLifecycleStatus @default(registered)
  activatedAt  DateTime?
  restrictedAt DateTime?
  frozenAt     DateTime?
  closedAt     DateTime?
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt
  wallets      Wallet[]

  @@index([status])
}

model Wallet {
  id                String            @id @default(cuid())
  customerAccountId String?
  customerAccount   CustomerAccount?  @relation(fields: [customerAccountId], references: [id])
  chainId           Int
  address           String
  kind              WalletKind
  custodyType       WalletCustodyType
  status            WalletStatus      @default(pending)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@unique([chainId, address])
  @@index([customerAccountId])
  @@index([kind, custodyType])
  @@index([status])
}

model Asset {
  id              String      @id @default(cuid())
  chainId         Int
  symbol          String
  displayName     String
  decimals        Int
  assetType       AssetType
  contractAddress String?
  status          AssetStatus @default(active)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@unique([chainId, symbol])
  @@unique([chainId, contractAddress])
  @@index([assetType, status])
}

model StakingPool {
  id                Int              @id @default(autoincrement())
  blockchainPoolId  Int?             @unique
  rewardRate        Int
  totalStakedAmount BigInt           @default(0)
  totalRewardsPaid  BigInt           @default(0)
  poolStatus        PoolStatus       @default(disabled)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  deposits          PoolDeposit[]
  withdrawals       PoolWithdrawal[]
}

enum AccountLifecycleStatus {
  registered
  email_verified
  review_required
  active
  restricted
  frozen
  closed
}

enum WalletKind {
  embedded
  external
  treasury
  operational
  contract
}

enum WalletCustodyType {
  platform_managed
  customer_external
  multisig_controlled
  contract_controlled
}

enum WalletStatus {
  pending
  active
  restricted
  archived
}

enum AssetType {
  native
  erc20
}

enum AssetStatus {
  active
  disabled
}

enum PoolStatus {
  active
  disabled
  paused
  closed
  completed
}

model PoolDeposit {
  id              Int           @id @default(autoincrement())
  userId          Int
  user            User          @relation(fields: [userId], references: [id])
  stakingPoolId   Int
  stakingPool     StakingPool   @relation(fields: [stakingPoolId], references: [id])
  amountStaked    BigInt
  transactionHash String?       @unique @default("")
  status          DepositStatus @default(pending)
  timestamp       DateTime      @default(now())
}

enum DepositStatus {
  pending
  completed
  failed
}

model PoolWithdrawal {
  id              Int              @id @default(autoincrement())
  userId          Int
  user            User             @relation(fields: [userId], references: [id])
  stakingPoolId   Int
  stakingPool     StakingPool      @relation(fields: [stakingPoolId], references: [id])
  amountWithdrawn BigInt
  transactionHash String?          @unique @default("")
  status          WithdrawalStatus @default(pending)
  timestamp       DateTime         @default(now())
}

enum WithdrawalStatus {
  pending
  completed
  failed
}
