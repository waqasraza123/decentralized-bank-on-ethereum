{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "artifacts/**", "cache/**", "typechain-types/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {},
    "test": {},
    "compile": {
      "outputs": ["artifacts/**", "cache/**", "typechain-types/**"]
    }
  }
}
